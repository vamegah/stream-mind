REDIS_DB=0

# AI Agent (to be used later)
OPENAI_API_KEY=your-key-here
LLM_MODEL=gpt-4o

# Privacy
PRIVACY_BUDGET_DAILY=1.0
PRIVACY_BUDGET_PER_QUERY=0.1